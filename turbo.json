{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": ["**/.env.local"],
  "globalEnv": [
    "SUPABASE_SERVICE_ROLE_KEY",
    "ZAPI_CLIENT_TOKEN",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_ZAPI_INSTANCE_ID",
    "NEXT_PUBLIC_ZAPI_TOKEN",
    "ANTHROPIC_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": [],
      "dependsOn": ["^type-check"]
    },
    "clean": {
      "cache": false
    }
  }
}
